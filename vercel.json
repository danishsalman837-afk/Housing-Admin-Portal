{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'self' https://as.primodialler.io" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/upload", "destination": "/api/attachments?action=upload" },
    { "source": "/api/delete-attachment", "destination": "/api/attachments?action=delete" },
    { "source": "/api/companies", "destination": "/api/crm?type=company" },
    { "source": "/api/members", "destination": "/api/crm?type=member" },
    { "source": "/api/update", "destination": "/api/leads-admin?route=update" },
    { "source": "/api/get-lead", "destination": "/api/leads-admin?route=get" },
    { "source": "/api/submissions", "destination": "/api/leads-admin?route=list" },
    { "source": "/api/submit", "destination": "/api/leads-public?route=submit" },
    { "source": "/api/save-draft", "destination": "/api/leads-public?route=draft" }
  ]
}
